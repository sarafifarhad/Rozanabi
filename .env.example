# Zoho SMTP for Rozana Contact Form
ZOHO_SMTP_HOST=smtp.zoho.com
ZOHO_SMTP_PORT=465
ZOHO_SMTP_USER=contact@rozanabi.com
ZOHO_SMTP_PASS=replace-with-zoho-app-password

CONTACT_TO_EMAIL=contact@rozanabi.com
CONTACT_FROM_EMAIL=Rozana Website <contact@rozanabi.com>
CONTACT_CSRF_SECRET=replace-with-a-long-random-secret
CONTACT_RATE_LIMIT_MAX=8
CONTACT_ERROR_WEBHOOK_URL=
ZOHO_SMTP_TIMEOUT_MS=15000
ZOHO_SMTP_RETRY_ATTEMPTS=2

# Cloudflare Turnstile
TURNSTILE_SECRET_KEY=replace-with-cloudflare-turnstile-secret-key
NEXT_PUBLIC_TURNSTILE_SITE_KEY=replace-with-cloudflare-turnstile-site-key

# Google monitoring / measurement tools
# Recommended: set GTM and configure GA4 + Google Ads inside Google Tag Manager.
NEXT_PUBLIC_GTM_CONTAINER_ID=GTM-XXXXXXX
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_ID=AW-XXXXXXXXXX
NEXT_PUBLIC_GOOGLE_TOOLS_LOAD_MODE=gtm_preferred
NEXT_PUBLIC_GOOGLE_TOOLS_DEBUG=false
NEXT_PUBLIC_REQUIRE_COOKIE_CONSENT=true
NEXT_PUBLIC_COOKIE_CONSENT_STORAGE_KEY=rz-cookie-consent
NEXT_PUBLIC_PRIMARY_DOMAIN=https://rozanabi.com
NEXT_PUBLIC_WWW_DOMAIN=https://www.rozanabi.com
